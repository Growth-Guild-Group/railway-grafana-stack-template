ARG VERSION=11.5.2

FROM grafana/grafana-oss:${VERSION}

# Provisioning: datasources + the dashboard provider + dashboard models.
COPY datasources /etc/grafana/provisioning/datasources
# dashboards.yaml is a FILE (the dashboard provider) — copy it INTO the provisioning dir.
COPY provisioning/dashboards.yaml /etc/grafana/provisioning/dashboards/
# The dashboard JSON models live where the provider's options.path points.
COPY dashboards /etc/grafana/dashboards
# Alerting: contact points + notification policy + rules.
COPY alerting /etc/grafana/provisioning/alerting